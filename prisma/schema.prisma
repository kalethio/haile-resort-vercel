generator client {
  provider = "prisma-client-js"
  seed     = "tsx prisma/seed.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  permissions Permission[]
  users       User[]
}

model Permission {
  id     Int    @id @default(autoincrement())
  module String
  action String
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@index([module, action])
}

model User {
  id        Int        @id @default(autoincrement())
  name      String?
  email     String     @unique
  password  String?
  roleId    Int?
  branchId  Int?
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
  branch    Branch?    @relation(fields: [branchId], references: [id])
  role      Role?      @relation(fields: [roleId], references: [id])

  @@index([branchId, roleId])
  @@index([email, status])
}

model ApiConnection {
  id        Int       @id @default(autoincrement())
  name      String
  type      String
  status    String
  apiKey    String?
  config    Json?
  lastTest  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  userId     Int?
  userEmail  String?
  targetType String?
  targetId   Int?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Branch {
  id               Int               @id @default(autoincrement())
  slug             String            @unique
  branchName       String
  description      String?
  heroImage        String?
  directionsUrl    String?
  starRating       Int?
  published        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  email            String?
  phone            String?
  accommodations   Accommodation[]
  attractions      Attraction[]
  auditLogs        AuditLog[]
  bookings         Booking[]
  seo              BranchSeo?
  chatbotResponses ChatbotResponse[]
  contact          Contact?
  experiences      Experience[]
  faqs             FAQ[]
  galleryItems     Gallery[]
  guests           Guest[]
  jobOpenings      JobOpening[]
  location         Location?
  mediaAssets      MediaAsset[]
  newsArticles     NewsArticle[]
  packages         Package[]
  promoCodes       PromoCode[]
  reviews          Review[]
  rooms            Room[]
  roomTypes        RoomType[]
  teamMembers      TeamMember[]
  staff            User[]
  websitePages     WebsitePage[]

  @@index([published, slug])
}

model Guest {
  id               Int                    @id @default(autoincrement())
  email            String                 @unique
  firstName        String
  lastName         String
  phone            String?
  preferences      Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  branchId         Int
  guestType        GuestType              @default(REGULAR)
  company          String?
  notes            String?
  totalStays       Int                    @default(0)
  totalNights      Int                    @default(0)
  lifetimeValue    Float                  @default(0)
  lastStayAt       DateTime?
  bookings         Booking[]
  branch           Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  favoritePackages GuestFavoritePackage[]
  loyaltyPoints    LoyaltyPoints[]
  reviews          Review[]

  @@index([branchId, email])
}

model RoomFeature {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  price       Float
  available   Boolean    @default(true)
  branchId    Int
  roomTypes   RoomType[] @relation("RoomFeatureToRoomType")

  @@index([branchId, available])
}

model RoomType {
  id               Int             @id @default(autoincrement())
  name             String
  description      String?
  capacity         Int
  childrenCapacity Int             @default(0)
  basePrice        Float
  amenities        Json?
  available        Boolean         @default(true)
  totalRooms       Int
  branchId         Int
  rooms            Room[]
  branch           Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomTypeMedia    RoomTypeMedia[]
  roomFeatures     RoomFeature[]   @relation("RoomFeatureToRoomType")

  @@unique([branchId, name])
  @@index([branchId, available])
}

model Room {
  id           Int           @id @default(autoincrement())
  roomNumber   String
  floor        String?
  features     Json?
  status       RoomStatus    @default(AVAILABLE)
  roomTypeId   Int
  branchId     Int
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType     RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  roomBookings RoomBooking[]

  @@unique([branchId, roomNumber])
  @@index([roomTypeId, status])
}

model Booking {
  id              String           @id @default(uuid())
  type            BookingType      @default(ROOM)
  status          BookingStatus    @default(PENDING)
  guestName       String
  guestEmail      String
  guestPhone      String?
  guestCountry    String?
  specialRequests String?
  checkIn         DateTime
  checkOut        DateTime
  adults          Int
  children        Int
  infants         Int?             @default(0)
  baseAmount      Float
  taxAmount       Float            @default(0)
  discountAmount  Float            @default(0)
  totalAmount     Float
  currency        String           @default("USD")
  pointsUsed      Int?             @default(0)
  pointsEarned    Int?
  promoCodeId     Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  confirmedAt     DateTime?
  branchId        Int
  guestId         Int?
  promoCode       PromoCode?       @relation(fields: [promoCodeId], references: [id])
  guest           Guest?           @relation(fields: [guestId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  loyaltyPoints   LoyaltyPoints[]
  packageBookings PackageBooking[]
  payments        Payment[]
  roomBookings    RoomBooking[]

  @@index([branchId, status])
  @@index([branchId, checkIn, checkOut])
  @@index([guestEmail])
}

model RoomBooking {
  id            Int     @id @default(autoincrement())
  pricePerNight Float
  totalNights   Int
  bookingId     String
  roomId        Int
  room          Room    @relation(fields: [roomId], references: [id])
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([roomId, bookingId])
  @@index([bookingId])
}

model Payment {
  id              Int           @id @default(autoincrement())
  amount          Float
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  isInternational Boolean       @default(false)
  currency        String        @default("USD")
  createdAt       DateTime      @default(now())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
}

model Package {
  id              Int                    @id @default(autoincrement())
  externalId      String?
  title           String
  subtitle        String?
  description     String?
  image           String?
  price           Float?
  duration        String?
  inclusions      Json?
  category        PackageCategory
  available       Boolean                @default(true)
  ctaLabel        String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  branchId        Int
  experienceId    Int?
  favoriteOf      GuestFavoritePackage[]
  branch          Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  experience      Experience?            @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  packageBookings PackageBooking[]
  packageMedia    PackageMedia[]

  @@index([branchId, available])
  @@index([experienceId])
  @@index([category])
}

model PackageBooking {
  id                  Int       @id @default(autoincrement())
  packageTitle        String
  packageDescription  String?
  packagePrice        Float
  startDate           DateTime
  endDate             DateTime?
  additionalServices  Json?
  guestCount          Int
  specialInstructions String?
  bookingId           String
  packageId           Int
  booking             Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package             Package   @relation(fields: [packageId], references: [id])

  @@index([packageId, startDate])
}

model GuestFavoritePackage {
  id        Int      @id @default(autoincrement())
  guestId   Int
  packageId Int
  createdAt DateTime @default(now())
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([guestId, packageId])
}

model MediaAsset {
  id            Int             @id @default(autoincrement())
  filename      String
  url           String
  type          String
  size          Int?
  createdAt     DateTime        @default(now())
  branchId      Int
  galleryItems  Gallery[]
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  packageMedia  PackageMedia[]
  roomTypeMedia RoomTypeMedia[]

  @@index([branchId, type])
}

model RoomTypeMedia {
  id          Int        @id @default(autoincrement())
  isHighlight Boolean    @default(false)
  order       Int        @default(0)
  roomTypeId  Int
  mediaId     Int
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  roomType    RoomType   @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, mediaId])
  @@index([roomTypeId, isHighlight])
}

model PackageMedia {
  id          Int        @id @default(autoincrement())
  isHighlight Boolean    @default(false)
  order       Int        @default(0)
  packageId   Int
  mediaId     Int
  package     Package    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([packageId, mediaId])
  @@index([packageId, isHighlight])
}

model Gallery {
  id         Int        @id @default(autoincrement())
  title      String?
  categories Json?
  type       String
  order      Int        @default(0)
  published  Boolean    @default(true)
  mediaId    Int
  branchId   Int
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  media      MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([branchId, published])
}

model WebsitePage {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, published])
}

model NewsArticle {
  id            Int      @id @default(autoincrement())
  title         String
  content       String
  excerpt       String?
  featuredImage String?
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, published, createdAt])
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  rating    Int
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  guestId   Int?
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  guest     Guest?   @relation(fields: [guestId], references: [id])

  @@index([branchId, approved, rating])
  @@index([guestId])
}

model JobOpening {
  id               Int              @id @default(autoincrement())
  title            String
  department       String?
  description      String
  requirements     Json?
  location         String?
  type             String?
  published        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  branchId         Int
  deadline         DateTime?
  experienceLevel  String?
  responsibilities Json?
  salaryRange      String?
  applications     JobApplication[]
  branch           Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, published, type])
}

model JobApplication {
  id                Int               @id @default(autoincrement())
  jobId             Int
  fullName          String
  email             String
  phone             String?
  currentLocation   String?
  educationLevel    String?
  yearsExperience   Int?
  skills            Json?
  languages         Json?
  certifications    Json?
  availabilityDate  DateTime?
  willingToRelocate Boolean
  expectedSalary    String?
  coverLetter       String?
  resumeUrl         String?
  status            ApplicationStatus @default(PENDING)
  submittedAt       DateTime          @default(now())
  job               JobOpening        @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status, submittedAt])
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  position  String
  bio       String?
  image     String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, published, order])
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, category, published])
}

model ChatbotResponse {
  id       Int     @id @default(autoincrement())
  triggers Json?
  response String
  role     String?
  order    Int     @default(0)
  active   Boolean @default(true)
  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])
  type     String? @default("RESPONSE") 
  
  @@index([branchId, active, role, type])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([email, active])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  subject   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          Int       @id @default(autoincrement())
  subject     String
  content     String
  targetCount Int
  status      String
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

model PromoCode {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Float
  minimumAmount Float?
  validFrom     DateTime
  validUntil    DateTime
  usageLimit    Int?
  usedCount     Int          @default(0)
  active        Boolean      @default(true)
  branchId      Int?
  bookings      Booking[]
  branch        Branch?      @relation(fields: [branchId], references: [id])

  @@index([code, active, branchId])
}

model LoyaltyPoints {
  id        Int       @id @default(autoincrement())
  points    Int
  reason    String
  expiresAt DateTime?
  guestId   Int
  bookingId String?
  createdAt DateTime  @default(now())
  booking   Booking?  @relation(fields: [bookingId], references: [id])
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId, expiresAt])
}

model Contact {
  id        Int      @id @default(autoincrement())
  phone     String?
  email     String?
  address   String?
  socials   Json?
  branchId  Int      @unique
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Attraction {
  id         Int      @id @default(autoincrement())
  externalId String?
  label      String
  image      String?
  branchId   Int
  createdAt  DateTime @default(now())
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Accommodation {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  image       String?
  branchId    Int
  createdAt   DateTime @default(now())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Experience {
  id             Int       @id @default(autoincrement())
  externalId     String?
  title          String
  description    String?
  highlightImage String?
  branchId       Int
  createdAt      DateTime  @default(now())
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  packages       Package[]
}

model BranchSeo {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?
  keywords    Json?
  branchId    Int      @unique
  createdAt   DateTime @default(now())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String?
  region    String?
  country   String?
  branchId  Int      @unique
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

enum PackageCategory {
  FAMILY
  ROMANTIC
  WELLNESS
  CULTURAL
  NATURE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLEANING
}

enum BookingType {
  ROOM
  PACKAGE
  COMBINED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  DIGITAL_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_NIGHT
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum GuestType {
  REGULAR
  FREQUENT
  CORPORATE
  VIP
  CELEBRITY
}
